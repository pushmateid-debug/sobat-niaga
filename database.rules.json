{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "users": {
      ".indexOn": ["email"],
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('admins').child(auth.uid).exists() || auth.token.email === 'pushmate.id@gmail.com')",
        ".write": "auth != null && ($uid === auth.uid || root.child('admins').child(auth.uid).exists() || auth.token.email === 'pushmate.id@gmail.com')",
        "sellerInfo": {
          ".validate": "auth.token.email === 'pushmate.id@gmail.com' || ((!newData.hasChild('balance') && !data.hasChild('balance')) || (newData.child('balance').val() === (data.child('balance').exists() ? data.child('balance').val() : 0))) && ((!newData.hasChild('points_event') && !data.hasChild('points_event')) || (newData.child('points_event').val() === (data.child('points_event').exists() ? data.child('points_event').val() : 0)))"
        }
      }
    },
    "products": {
      ".read": true,
      "$productId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name', 'price'])"
      }
    },
    "orders": {
      ".read": "auth != null",
      "$orderId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['buyerId', 'totalPrice'])"
      }
    },
    "admin": {
      ".read": true,
      ".write": "auth != null && auth.token.email === 'pushmate.id@gmail.com'"
    },
    "chats": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || auth.token.email === 'pushmate.id@gmail.com')",
        ".write": "auth != null && ($uid === auth.uid || auth.token.email === 'pushmate.id@gmail.com')"
      }
    },
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["userId"]
    },
    "drivers_locations": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && $uid === auth.uid"
      }
    },
    "food_delivery_pool": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "reviews": {
      ".read": true,
      ".write": "auth != null"
    },
    "withdrawals": {
      ".read": "auth != null && (data.child('userId').val() === auth.uid || auth.token.email === 'pushmate.id@gmail.com')",
      ".write": "auth != null"
    }
  }
}
